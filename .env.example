# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Postgres connection string (Settings → Database → Connection string → URI).
# Use the pooled "Transaction" port (6543) for serverless; required by Drizzle.
DATABASE_URL=postgresql://postgres:[password]@db.your-project.supabase.co:5432/postgres

# ─── LLM (OpenAI-compatible) ─────────────────────────────────────────────────
# provider: openai | deepseek | xai  (all three share the OpenAI chat API)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
OPENAI_API_KEY=sk-...
DEEPSEEK_API_KEY=sk-...
XAI_API_KEY=xai-...

# ─── Stripe (test mode) ──────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs created in the Stripe dashboard ($9/mo and $99/yr).
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_ANNUAL=price_...

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
